{
    "name": "atletis/despesas-api",
    "description": "API RESTful de gerenciamento de despesas pessoais construída com Yii2",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "yiisoft/yii2": "~2.0.49",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "codeception/codeception": "^5.1",
        "codeception/module-yii2": "^1.1",
        "codeception/module-asserts": "^3.0",
        "codeception/module-rest": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    }
}
