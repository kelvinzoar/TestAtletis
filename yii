#!/usr/bin/env php
<?php

/**
 * Ponto de entrada de linha de comando (console).
 * Usado para rodar as migrations (`php yii migrate`) e outros comandos de console.
 */

defined('YII_DEBUG') or define('YII_DEBUG', getenv('YII_DEBUG') === 'true' ?: true);
defined('YII_ENV') or define('YII_ENV', getenv('YII_ENV') ?: 'dev');

require __DIR__ . '/vendor/autoload.php';
require __DIR__ . '/vendor/yiisoft/yii2/Yii.php';

$config = require __DIR__ . '/config/console.php';

$application = new yii\console\Application($config);
$exitCode = $application->run();
exit($exitCode);
