# ------------------------------------------------------------------
# Variáveis de ambiente do projeto.
# Copie este arquivo para `.env` (o docker-compose lê o .env automaticamente)
# e ajuste os valores. O .env NÃO é versionado (está no .gitignore).
#
# Mantém segredos (senhas, chaves) fora do código-fonte, configuráveis por ambiente.
# ------------------------------------------------------------------

# Ambiente da aplicação (dev habilita mensagens de erro detalhadas)
YII_ENV=dev
YII_DEBUG=true

# Banco de dados (o host "mysql" é o nome do serviço no docker-compose)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=despesas
DB_USER=despesas
DB_PASSWORD=despesas_secret
DB_ROOT_PASSWORD=root_secret

# JWT — segredo usado para assinar/validar os tokens (HS256).
# Em produção, gere uma chave longa e aleatória e NUNCA a versione.
JWT_SECRET=troque-esta-chave-por-uma-bem-longa-e-aleatoria
JWT_ISSUER=despesas-api
JWT_TTL=3600
